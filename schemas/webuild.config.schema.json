{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://webuildsites.local/schemas/webuild.config.schema.json",
  "title": "Webuild Website Standard Config",
  "type": "object",
  "required": ["standard", "version", "project", "classification", "stack", "runtime", "commands", "deployment", "integrations", "maintenance"],
  "properties": {
    "standard": {
      "type": "string",
      "const": "webuild-website-standard"
    },
    "version": {
      "type": "string"
    },
    "project": {
      "type": "object",
      "required": ["name", "type", "status"],
      "properties": {
        "name": { "type": "string" },
        "client": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["website", "standard-repository", "template-repository", "tooling-repository"]
        },
        "status": { "type": "string" }
      },
      "additionalProperties": true
    },
    "classification": {
      "type": "object",
      "required": ["hostingMode", "reason"],
      "properties": {
        "hostingMode": {
          "type": "string",
          "enum": ["none", "static", "dynamic", "app"]
        },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "stack": {
      "type": "object",
      "required": ["framework", "language", "packageManager"],
      "properties": {
        "framework": { "type": "string" },
        "router": { "type": "string" },
        "language": { "type": "string" },
        "styling": { "type": "string" },
        "packageManager": { "type": "string" }
      },
      "additionalProperties": true
    },
    "runtime": {
      "type": "object",
      "required": [
        "requiresNodeServer",
        "usesApiRoutes",
        "usesMiddleware",
        "usesDatabase",
        "usesAuth",
        "usesPayments",
        "usesUploads",
        "usesBackgroundJobs",
        "usesPersistentStorage"
      ],
      "properties": {
        "requiresNodeServer": { "type": "boolean" },
        "usesApiRoutes": { "type": "boolean" },
        "usesMiddleware": { "type": "boolean" },
        "usesDatabase": { "type": "boolean" },
        "usesAuth": { "type": "boolean" },
        "usesPayments": { "type": "boolean" },
        "usesUploads": { "type": "boolean" },
        "usesBackgroundJobs": { "type": "boolean" },
        "usesPersistentStorage": { "type": "boolean" },
        "requiredEnv": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "commands": {
      "type": "object",
      "properties": {
        "install": { "type": "string" },
        "dev": { "type": "string" },
        "build": { "type": "string" },
        "start": { "type": "string" },
        "test": { "type": "string" },
        "validate": { "type": "string" }
      },
      "additionalProperties": false
    },
    "deployment": {
      "type": "object",
      "required": ["target", "engine", "containerized"],
      "properties": {
        "target": { "type": "string" },
        "engine": { "type": "string" },
        "containerized": { "type": "boolean" },
        "domain": { "type": "string" },
        "stagingDomain": { "type": "string" },
        "healthCheckPath": { "type": "string" },
        "port": { "type": ["number", "null"] }
      },
      "additionalProperties": true
    },
    "integrations": {
      "type": "object",
      "required": ["forms", "analytics", "cms", "database"],
      "properties": {
        "forms": { "$ref": "#/$defs/integration" },
        "analytics": { "$ref": "#/$defs/integration" },
        "cms": { "$ref": "#/$defs/integration" },
        "database": { "$ref": "#/$defs/integration" },
        "auth": { "$ref": "#/$defs/integration" },
        "payments": { "$ref": "#/$defs/integration" },
        "storage": { "$ref": "#/$defs/integration" }
      },
      "additionalProperties": true
    },
    "maintenance": {
      "type": "object",
      "required": ["uptimeMonitoring", "backups", "monthlyHealthCheck"],
      "properties": {
        "uptimeMonitoring": { "type": "boolean" },
        "backups": { "type": "boolean" },
        "monthlyHealthCheck": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "integration": {
      "type": "object",
      "required": ["provider", "requiredEnv"],
      "properties": {
        "provider": { "type": "string" },
        "requiredEnv": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
