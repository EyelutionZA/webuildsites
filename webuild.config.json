{
  "standard": "webuild-website-standard",
  "version": "2.0.0",
  "project": {
    "name": "webuildsites",
    "client": "Webuild",
    "type": "standard-repository",
    "status": "active"
  },
  "classification": {
    "hostingMode": "none",
    "reason": "This repository contains the Webuild Website Standard, Claude Code skill, templates, docs, and tooling. It is not itself a deployable website."
  },
  "stack": {
    "framework": "none",
    "router": "none",
    "language": "javascript",
    "styling": "none",
    "packageManager": "npm"
  },
  "runtime": {
    "requiresNodeServer": false,
    "usesApiRoutes": false,
    "usesMiddleware": false,
    "usesDatabase": false,
    "usesAuth": false,
    "usesPayments": false,
    "usesUploads": false,
    "usesBackgroundJobs": false,
    "usesPersistentStorage": false,
    "requiredEnv": []
  },
  "commands": {
    "install": "npm install",
    "test": "npm test",
    "validate": "npm run validate:config"
  },
  "deployment": {
    "target": "none",
    "engine": "none",
    "containerized": false,
    "domain": "",
    "stagingDomain": "",
    "healthCheckPath": "",
    "port": null
  },
  "integrations": {
    "forms": {
      "provider": "none",
      "requiredEnv": []
    },
    "analytics": {
      "provider": "none",
      "requiredEnv": []
    },
    "cms": {
      "provider": "none",
      "requiredEnv": []
    },
    "database": {
      "provider": "none",
      "requiredEnv": []
    },
    "auth": {
      "provider": "none",
      "requiredEnv": []
    },
    "payments": {
      "provider": "none",
      "requiredEnv": []
    },
    "storage": {
      "provider": "none",
      "requiredEnv": []
    }
  },
  "maintenance": {
    "uptimeMonitoring": false,
    "backups": true,
    "monthlyHealthCheck": true
  }
}
