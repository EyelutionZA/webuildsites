{
  "standard": "webuild-website-standard",
  "version": "2.0.0",
  "project": {
    "name": "next-dynamic-api-form-fixture",
    "client": "Fixture",
    "type": "website",
    "status": "fixture"
  },
  "classification": {
    "hostingMode": "dynamic",
    "reason": "Dynamic website fixture with an API route for server-side form handling."
  },
  "stack": {
    "framework": "nextjs",
    "router": "app",
    "language": "typescript",
    "styling": "none",
    "packageManager": "npm"
  },
  "runtime": {
    "requiresNodeServer": true,
    "usesApiRoutes": true,
    "usesMiddleware": false,
    "usesDatabase": false,
    "usesAuth": false,
    "usesPayments": false,
    "usesUploads": false,
    "usesBackgroundJobs": false,
    "usesPersistentStorage": false,
    "requiredEnv": ["FORM_WEBHOOK_URL"]
  },
  "commands": {
    "install": "npm install",
    "build": "npm run build",
    "start": "npm run start"
  },
  "deployment": {
    "target": "webuild-cloud",
    "engine": "coolify-compatible",
    "containerized": false,
    "domain": "",
    "stagingDomain": "",
    "healthCheckPath": "/api/contact",
    "port": 3000
  },
  "integrations": {
    "forms": { "provider": "api-route", "requiredEnv": ["FORM_WEBHOOK_URL"] },
    "analytics": { "provider": "none", "requiredEnv": [] },
    "cms": { "provider": "none", "requiredEnv": [] },
    "database": { "provider": "none", "requiredEnv": [] },
    "auth": { "provider": "none", "requiredEnv": [] },
    "payments": { "provider": "none", "requiredEnv": [] },
    "storage": { "provider": "none", "requiredEnv": [] }
  },
  "maintenance": {
    "uptimeMonitoring": true,
    "backups": true,
    "monthlyHealthCheck": true
  }
}
