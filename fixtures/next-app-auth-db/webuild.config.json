{
  "standard": "webuild-website-standard",
  "version": "2.0.0",
  "project": {
    "name": "next-app-auth-db-fixture",
    "client": "Fixture",
    "type": "website",
    "status": "fixture"
  },
  "classification": {
    "hostingMode": "app",
    "reason": "App fixture with auth, database and payment dependencies."
  },
  "stack": {
    "framework": "nextjs",
    "router": "app",
    "language": "typescript",
    "styling": "none",
    "packageManager": "npm"
  },
  "runtime": {
    "requiresNodeServer": true,
    "usesApiRoutes": false,
    "usesMiddleware": false,
    "usesDatabase": true,
    "usesAuth": true,
    "usesPayments": true,
    "usesUploads": false,
    "usesBackgroundJobs": false,
    "usesPersistentStorage": false,
    "requiredEnv": ["DATABASE_URL", "AUTH_SECRET", "STRIPE_SECRET_KEY"]
  },
  "commands": {
    "install": "npm install",
    "build": "npm run build",
    "start": "npm run start"
  },
  "deployment": {
    "target": "webuild-cloud",
    "engine": "coolify-compatible",
    "containerized": false,
    "domain": "",
    "stagingDomain": "",
    "healthCheckPath": "/api/health",
    "port": 3000
  },
  "integrations": {
    "forms": { "provider": "none", "requiredEnv": [] },
    "analytics": { "provider": "none", "requiredEnv": [] },
    "cms": { "provider": "none", "requiredEnv": [] },
    "database": { "provider": "postgres", "requiredEnv": ["DATABASE_URL"] },
    "auth": { "provider": "next-auth", "requiredEnv": ["AUTH_SECRET"] },
    "payments": { "provider": "stripe", "requiredEnv": ["STRIPE_SECRET_KEY"] },
    "storage": { "provider": "none", "requiredEnv": [] }
  },
  "maintenance": {
    "uptimeMonitoring": true,
    "backups": true,
    "monthlyHealthCheck": true
  }
}
