{
  "standard": "webuild-website-standard",
  "version": "2.0.0",
  "project": {
    "name": "next-static-site-fixture",
    "client": "Fixture",
    "type": "website",
    "status": "fixture"
  },
  "classification": {
    "hostingMode": "static",
    "reason": "Static marketing website fixture with no runtime server requirements."
  },
  "stack": {
    "framework": "nextjs",
    "router": "app",
    "language": "typescript",
    "styling": "none",
    "packageManager": "npm"
  },
  "runtime": {
    "requiresNodeServer": false,
    "usesApiRoutes": false,
    "usesMiddleware": false,
    "usesDatabase": false,
    "usesAuth": false,
    "usesPayments": false,
    "usesUploads": false,
    "usesBackgroundJobs": false,
    "usesPersistentStorage": false,
    "requiredEnv": []
  },
  "commands": {
    "install": "npm install",
    "build": "npm run build"
  },
  "deployment": {
    "target": "vercel",
    "engine": "vercel",
    "containerized": false,
    "domain": "",
    "stagingDomain": "",
    "healthCheckPath": "/",
    "port": null
  },
  "integrations": {
    "forms": { "provider": "none", "requiredEnv": [] },
    "analytics": { "provider": "google-analytics", "requiredEnv": ["NEXT_PUBLIC_GA_ID"] },
    "cms": { "provider": "none", "requiredEnv": [] },
    "database": { "provider": "none", "requiredEnv": [] },
    "auth": { "provider": "none", "requiredEnv": [] },
    "payments": { "provider": "none", "requiredEnv": [] },
    "storage": { "provider": "none", "requiredEnv": [] }
  },
  "maintenance": {
    "uptimeMonitoring": true,
    "backups": true,
    "monthlyHealthCheck": true
  }
}
